// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "git_hosting_providers": [
    {
      "provider": "gitlab",
      "name": "Picodata",
      "base_url": "https://git.picodata.io/",
    },
  ],
  "show_whitespaces": "trailing",
  "remove_trailing_whitespace_on_save": false,
  "tab_bar": {
    "show": false,
  },
  "soft_wrap": "editor_width",
  "disable_ai": true,
  "buffer_font_family": "Source Code Pro",
  "project_panel": {
    "dock": "left",
    "hide_hidden": true,
  },
  "theme_overrides": {
    "VSCode Dark Modern": {
      "vim.normal.background": "#153f69",
      "vim.insert.background": "#693e15",
      "vim.visual.background": "#197d3c",
      "vim.visual_line.background": "#197d3c",
      "vim.visual_block.background": "#197d3c",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "cursor_blink": false,
  "theme": {
    "mode": "system",
    "light": "VSCode Dark Modern",
    "dark": "VSCode Dark Modern",
  },
  "languages": {
    "Haskell": {
      "tab_size": 2,
    },
  },
}
